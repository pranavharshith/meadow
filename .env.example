# Copy to .env and fill in to enable the online "shared garden" layer.
# With these unset, the game runs fully offline (single-player, local save).
# Both values come from your Supabase project: Settings > API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: Cloudflare Turnstile site key to gate anonymous sign-ins against
# scripted identity-cycling. Leave empty to disable. When set, you must ALSO
# enable "CAPTCHA protection" in the Supabase dashboard (Auth > Settings)
# with the matching Turnstile secret key — otherwise Supabase ignores tokens.
# Get a free site key at https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY=
